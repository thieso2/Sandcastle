.sandboxes.active.where(tailscale: true).find_each do |sandbox|\n   119→      disconnect_sandbox(sandbox: sandbox)\n   120→    end\n   121→\n   122→    cleanup_sidecar(user)\n   123→\n   124→    user.update!(\n   125→      tailscale_state: \"disabled\",\n   126→      tailscale_container_id: nil,\n   127→      tailscale_network: nil\n   128→    )\n   129→    user\n   130→  rescue Docker::Error::DockerError => e\n   131→    raise Error, \"Failed to disable Tailscale: #{e.message}\"\n   132→  end\n   133→\n   134→  def status(user:)\n   135→    raise Error, \"Tailscale not active\" unless user.tailscale_enabled? || user.tailscale_pending?\n   136→    raise Error, \"Sidecar container not found\" if user.tailscale_container_id.blank?\n   137→\n   138→    container = Docker::Container.get(user.tailscale_container_id)\n   139→    running = container.json.dig(\"State\", \"Running\")\n   140→\n   141→    ts_sandboxes = user.sandboxes.active.where(tailscale: true)\n   142→    sandbox_ips = ts_sandboxes.map do |sb|\n   143→      ip = sandbox_tailscale_ip(sandbox: sb)\n   144→      { name: sb.name, ip: ip }\n   145→    end\n   146→\n   147→    result = {\n   148→      running: running,\n   149→      container_id: user.tailscale_container_id[0..11],\n   150→      network: user.tailscale_network,\n   151→      connected_sandboxes: ts_sandboxes.count,\n   152→      sandboxes: sandbox_ips\n   153→    }\n   154→\n   155→    if running\n   156→      ip_out = container.exec([ \"tailscale\", \"ip\", \"--4\" ])\n   157→      result[:tailscale_ip] = ip_out.first.first&.strip if ip_out.first.any?\n   158→\n   159→      status_out = container.exec([ \"tailscale\", \"status\", \"--json\" ])\n   160→      if status_out.first.any?\n   161→        begin\n   162→          ts_status = JSON.parse(status_out.first.join)\n   163→          result[:hostname] = ts_status.dig(\"Self\", \"HostName\")\n   164→          result[:tailnet] = ts_status.dig(\"MagicDNSSuffix\")\n   165→          result[:online] = ts_status.dig(\"Self\", \"Online\")\n   166→          tags = ts_status.dig(\"Self\", \"Tags\")\n   167→          result[:tags] = tags if tags.present?\n   168→        rescue JSON::ParserError\n   169→          # Status not available yet\n   170→        end\n   171→      end\n   172→    else\n   173→      # Grab last 20 lines of container logs for debugging\n   174→      logs = container.logs(stdout: true, stderr: true, tail: 20)\n   175→      result[:logs] = logs.encode(\"UTF-8\", invalid: :replace, undef: :replace).strip if logs.present?\n   176→      result[:exit_code] = container.json.dig(\"State\", \"ExitCode\")\n   177→      result[:error_reason] = container.json.dig(\"State\", \"Error\")\n   178→    end\n   179→\n   180→    result\n   181→  rescue Docker::Error::NotFoundError\n   182→    raise Error, \"Sidecar container not found — try disabling and re-enabling Tailscale\"\n   183→  rescue Docker::Error::DockerError => e\n   184→    raise Error, \"Failed to get Tailscale status: #{e.message}\"\n   185→  end\n   186→\n   187→  def connect_sandbox(sandbox:)\n   188→    user = sandbox.user\n   189→    raise Error, \"Tailscale not enabled for user\" unless user.tailscale_enabled?\n   190→    raise Error, \"Sandbox not running\" unless sandbox.container_id.present?\n   191→\n   192→    network = Docker::Network.get(user.tailscale_network)\n   193→    network.connect(sandbox.container_id)\n   194→    sandbox.update!(tailscale: true)\n   195→    sandbox\n   196→  rescue Docker::Error::DockerError => e\n   197→    raise Error, \"Failed to connect sandbox to Tailscale: #{e.message}\"\n   198→  end\n   199→\n   200→  def disconnect_sandbox(sandbox:)\n   201→    user = sandbox.user\n   202→    return sandbox unless sandbox.tailscale? && user.tailscale_network.present?\n   203→\n   204→    if sandbox.container_id.present?\n   205→      begin\n   206→        network = Docker::Network.get(user.tailscale_network)\n   207→        network.disconnect(sandbox.container_id)\n   208→      rescue Docker::Error::NotFoundError, Docker::Error::DockerError\n   209→        # Network/container already gone or container not connected — desired state reached\n   210→      end\n   211→    end\n   212→\n   213→    sandbox.update!(tailscale: false)\n   214→    sandbox\n   215→  rescue Docker::Error::DockerError => e\n   216→    raise Error, \"Failed to disconnect sandbox from Tailscale: #{e.message}\"\n   217→  end\n   218→\n   219→  def sandbox_tailscale_ip(sandbox:)\n   220→    user = sandbox.user\n   221→    return nil unless sandbox.tailscale? && sandbox.container_id.present? && user.tailscale_network.present?\n   222→\n   223→    container = Docker::Container.get(sandbox.container_id)\n   224→    container.json.dig(\"NetworkSettings\", \"Networks\", user.tailscale_network, \"IPAddress\")\n   225→  rescue Docker::Error::DockerError\n   226→    nil\n   227→  end\n   228→\n   229→  private\n   230→\n   231→  def create_and_start_sidecar(user:, auth_key:, hostname: nil)\n   232→    network_name = \"sc-ts-net-#{user.name}\"\n   233→    container_name = \"sc-ts-#{user.name}\"\n   234→    subnet = subnet_for(user)\n   235→\n   236→    pull_image\n   237→    create_network(network_name, subnet)\n   238→    remove_existing_container(container_name)\n   239→    clear_tailscale_state(user)\n   240→    container = create_sidecar(\n   241→      name: container_name,\n   242→      user: user,\n   243→      network: network_name,\n   244→      subnet: subnet,\n   245→      auth_key: auth_key,\n   246→      hostname: hostname\n   247→    )\n   248→    container.start\n   249→\n   250→    [ network_name, container ]\n   251→  end\n   252→\n   253→  def remove_existing_container(name)\n   254→    container = Docker::Container.get(name)\n   255→    container.stop(t: 5) rescue nil\n   256→    container.delete(force: true)\n   257→  rescue Docker::Error::NotFoundError\n   258→    # No existing container\n   259→  end\n   260→\n   261→  # Remove stale tailscaled.state so the daemon starts fresh.\n   262→  # Stale state causes tailscaled to immediately set up VPN routes before\n   263→  # authentication, which silently drops all normal internet traffic.\n   264→  def clear_tailscale_state(user)\n   265→    state_file = \"#{DATA_DIR}/users/#{user.name}/tailscale/tailscaled.state\"\n   266→    File.delete(state_file) if File.exist?(state_file)\n   267→  rescue Errno::ENOENT\n   268→    # already gone\n   269→  end\n   270→\n   271→  def cleanup_sidecar(user)\n   272→    # Try by stored container ID first, then by name as fallback\n   273→    container_name = \"sc-ts-#{user.name}\"\n   274→    [user.tailscale_container_id, container_name].compact.uniq.each do |ref|\n   275→      begin\n   276→        container = Docker::Container.get(ref)\n   277→        container.stop(t: 5) rescue nil\n   278→        container.delete(force: true)\n   279→      rescue Docker::Error::NotFoundError\n   280→        # Already gone\n   281→      end\n   282→    end\n   283→\n   284→    # Clean up network by stored name, then by convention\n   285→    network_name = \"sc-ts-net-#{user.name}\"\n   286→    [user.tailscale_network, network_name].compact.uniq.each do |ref|\n   287→      begin\n   288→        Docker::Network.get(ref).delete\n   289→      rescue Docker::Error::NotFoundError\n   290→        # Already gone\n   291→      end\n   292→    end\n   293→  end\n   294→\n   295→  def cleanup_on_failure(user)\n   296→    container_name = \"sc-ts-#{user.name}\"\n   297→    network_name = \"sc-ts-net-#{user.name}\"\n   298→    begin\n   299→      Docker::Container.get(container_name).delete(force: true)\n   300→    rescue StandardError\n   301→      nil\n   302→    end\n   303→    begin\n   304→      Docker::Network.get(network_name).delete\n   305→    rescue StandardError\n   306→      nil\n   307→    end\n   308→    user.update!(tailscale_state: \"disabled\", tailscale_container_id: nil, tailscale_network: nil)\n   309→  end\n   310→\n   311→  def pull_image\n   312→    Docker::Image.get(TAILSCALE_IMAGE)\n   313→  rescue Docker::Error::NotFoundError\n   314→    Docker::Image.create(\"fromImage\" => TAILSCALE_IMAGE)\n   315→  rescue Docker::Error::DockerError\n   316→    raise Error, \"Failed to pull #{TAILSCALE_IMAGE} — check network connectivity\"\n   317→  end\n   318→\n   319→  def subnet_for(user)\n   320→    # If the network already exists, read its actual subnet (stable across restarts)\n   321→    begin\n   322→      network = Docker::Network.get(\"sc-ts-net-#{user.name}\")\n   323→      ipam = network.info.dig(\"IPAM\", \"Config\")\n   324→      return ipam.first[\"Subnet\"] if ipam&.first\n   325→    rescue Docker::Error::NotFoundError\n   326→      # Network doesn't exist yet — fall through to generate a random /24\n   327→    end\n   328→\n   329→    base = ENV[\"DOCKYARD_POOL_BASE\"]\n   330→    if base\n   331→      parts = base.split(\"/\").first.split(\".\").map(&:to_i)\n   332→    else\n   333→      parts = [ 10, rand(1..254), 0, 0 ]\n   334→    end\n   335→    parts[2] = rand(1..254)\n   336→    \"#{parts[0]}.#{parts[1]}.#{parts[2]}.0/24\"\n   337→  end\n   338→\n   339→  def create_network(name, subnet)\n   340→    Docker::Network.get(name)\n   341→  rescue Docker::Error::NotFoundError\n   342→    Docker::Network.create(\n   343→      name,\n   344→      \"Driver\" => \"bridge\",\n   345→      \"IPAM\" => {\n   346→        \"Config\" => [ { \"Subnet\" => subnet } ]\n   347→      }\n   348→    )\n   349→  end\n   350→\n   351→  def create_sidecar(name:, user:, network:, subnet:, auth_key:, hostname: nil)\n   352→    state_dir = \"#{DATA_DIR}/users/#{user.name}/tailscale\"\n   353→    ts_hostname = hostname.presence || \"sc-#{user.name}\"\n   354→\n   355→    config = {\n   356→      \"Image\" => TAILSCALE_IMAGE,\n   357→      \"name\" => name,\n   358→      \"Hostname\" => ts_hostname,\n   359→      \"HostConfig\" => {\n   360→        \"NetworkMode\" => network,\n   361→        \"CapAdd\" => [ \"NET_ADMIN\", \"SYS_MODULE\" ],\n   362→        \"Devices\" => [\n   363→          { \"PathOnHost\" => \"/dev/net/tun\", \"PathInContainer\" => \"/dev/net/tun\", \"CgroupPermissions\" => \"rwm\" }\n   364→        ],\n   365→        \"Sysctls\" => { \"net.ipv4.ip_forward\" => \"1\" },\n   366→        \"Binds\" => [ \"#{state_dir}:/var/lib/tailscale\" ],\n   367→        \"RestartPolicy\" => { \"Name\" => \"unless-stopped\" }\n   368→      }\n   369→    }\n   370→\n   371→    if auth_key.present?\n   372→      # Use containerboot (default entrypoint) with auth key for automated flow\n   373→      config[\"Env\"] = [\n   374→        \"TS_STATE_DIR=/var/lib/tailscale\",\n   375→        \"TS_HOSTNAME=#{ts_hostname}\",\n   376→        \"TS_EXTRA_ARGS=--advertise-routes=#{subnet} --accept-routes#{TAILSCALE_TAG ? \" --advertise-tags=#{TAILSCALE_TAG}\" : \"\"}\",\n   377→        \"TS_AUTH_ONCE=true\",\n   378→        \"TS_AUTHKEY=#{auth_key}\"\n   379→      ]\n   380→    else\n   381→      # Run tailscaled directly — we manage login via `tailscale up`\n   382→      config[\"Entrypoint\"] = [ \"tailscaled\", \"--state=/var/lib/tailscale/tailscaled.state\" ]\n   383→      config[\"Cmd\"] = []\n   384→    end\n   385→\n   386→    Docker::Container.create(config)\n   387→  end\n   388→end\n   389→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"uuid":"2191ed4f-c5b4-4cdf-97c5-bd5259162dcb","timestamp":"2026-02-21T16:38:05.916Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/thies/Projects/GitHub/Sandcastle/app/services/tailscale_manager.rb","content":"class TailscaleManager\n  DATA_DIR = ENV.fetch(\"SANDCASTLE_DATA_DIR\", \"/data\")\n  TAILSCALE_IMAGE = \"tailscale/tailscale:latest\"\n  TAILSCALE_TAG = ENV.fetch(\"SANDCASTLE_TAILSCALE_TAG\", \"\").presence\n  LOGIN_URL_PATTERN = %r{https://login\\.tailscale\\.com/\\S+}\n\n  class Error < StandardError; end\n\n  # Legacy: one-shot enable with an auth key (still supported for automation)\n  def enable(user:, auth_key:)\n    raise Error, \"Tailscale already active\" if user.tailscale_enabled? || user.tailscale_pending?\n\n    network_name, container = create_and_start_sidecar(user: user, auth_key: auth_key)\n\n    user.update!(\n      tailscale_state: \"enabled\",\n      tailscale_auto_connect: true,\n      tailscale_container_id: container.id,\n      tailscale_network: network_name\n    )\n    user\n  rescue Docker::Error::DockerError => e\n    cleanup_on_failure(user)\n    raise Error, \"Failed to enable Tailscale: #{e.message}\"\n  end\n\n  # Phase 1: create and start sidecar, return immediately\n  def start_login(user:)\n    raise Error, \"Tailscale already active\" if user.tailscale_enabled?\n\n    # If pending, clean up the old attempt first\n    cleanup_sidecar(user) if user.tailscale_pending?\n\n    hostname = Rails.cache.read(\"ts_hostname:#{user.id}\")\n    network_name, container = create_and_start_sidecar(user: user, auth_key: nil, hostname: hostname)\n\n    user.update!(\n      tailscale_state: \"pending\",\n      tailscale_container_id: container.id,\n      tailscale_network: network_name\n    )\n\n    { status: \"starting\" }\n  rescue Docker::Error::DockerError => e\n    cleanup_on_failure(user)\n    raise Error, \"Failed to start Tailscale login: #{e.message}\"\n  end\n\n  # Phase 2: progressive login status check\n  # Returns: { status: \"starting\" | \"waiting_for_url\" | \"login_ready\" | \"authenticated\" | \"error\" }\n  def check_login(user:)\n    raise Error, \"No pending login\" unless user.tailscale_pending?\n    raise Error, \"Sidecar container not found\" if user.tailscale_container_id.blank?\n\n    container = Docker::Container.get(user.tailscale_container_id)\n    running = container.json.dig(\"State\", \"Running\")\n    return { status: \"starting\", message: \"Starting sidecar container...\" } unless running\n\n    # Kick off `tailscale up` in the background if not already done\n    cache_key = \"ts_login_started:#{user.id}\"\n    unless Rails.cache.read(cache_key)\n      subnet = subnet_for(user)\n      tag = Rails.cache.read(\"ts_tag:#{user.id}\") || TAILSCALE_TAG\n      tag_flag = tag ? \" --advertise-tags=#{tag}\" : \"\"\n      container.exec([\n        \"sh\", \"-c\",\n        \"tailscale up --reset\" \\\n        \" --advertise-routes=#{subnet}\" \\\n        \"#{tag_flag}\" \\\n        \" --hostname=#{container.json.dig(\"Config\", \"Hostname\")}\" \\\n        \" --timeout=120s &\"\n      ])\n      Rails.cache.write(cache_key, true, expires_in: 5.minutes)\n      return { status: \"waiting_for_url\", message: \"Waiting for login URL...\" }\n    end\n\n    # Check tailscale status for auth progress\n    status_out = container.exec([ \"tailscale\", \"status\", \"--json\" ])\n    if status_out.first.any?\n      ts_status = JSON.parse(status_out.first.join)\n      case ts_status[\"BackendState\"]\n      when \"Running\"\n        Rails.cache.delete(cache_key)\n        user.update!(tailscale_state: \"enabled\", tailscale_auto_connect: true)\n        ip_out = container.exec([ \"tailscale\", \"ip\", \"--4\" ])\n        tailscale_ip = ip_out.first.first&.strip if ip_out.first.any?\n        return {\n          status: \"authenticated\",\n          tailscale_ip: tailscale_ip,\n          hostname: ts_status.dig(\"Self\", \"HostName\"),\n          tailnet: ts_status.dig(\"MagicDNSSuffix\")\n        }\n      when \"NeedsLogin\"\n        auth_url = ts_status[\"AuthURL\"]\n        if auth_url.present?\n          return { status: \"login_ready\", login_url: auth_url, message: \"Click the link to authenticate\" }\n        end\n      end\n    end\n\n    { status: \"waiting_for_url\", message: \"Waiting for login URL...\" }\n  rescue JSON::ParserError\n    { status: \"waiting_for_url\", message: \"Waiting for login URL...\" }\n  rescue Docker::Error::NotFoundError\n    Rails.cache.delete(\"ts_login_started:#{user.id}\")\n    user.update!(tailscale_state: \"disabled\", tailscale_container_id: nil, tailscale_network: nil)\n    raise Error, \"Sidecar container disappeared\"\n  rescue Docker::Error::DockerError => e\n    raise Error, \"Failed to check login: #{e.message}\"\n  end\n\n  def disable(user:)\n    raise Error, \"Tailscale not active\" if user.tailscale_disabled?\n\n    Rails.cache.delete(\"ts_login_started:#{user.id}\")\n\n    # Disconnect all sandboxes first\n    user.sandboxes.active.where(tailscale: true).find_each do |sandbox|\n      disconnect_sandbox(sandbox: sandbox)\n    end\n\n    cleanup_sidecar(user)\n\n    user.update!(\n      tailscale_state: \"disabled\",\n      tailscale_container_id: nil,\n      tailscale_network: nil\n    )\n    user\n  rescue Docker::Error::DockerError => e\n    raise Error, \"Failed to disable Tailscale: #{e.message}\"\n  end\n\n  def status(user:)\n    raise Error, \"Tailscale not active\" unless user.tailscale_enabled? || user.tailscale_pending?\n    raise Error, \"Sidecar container not found\" if user.tailscale_container_id.blank?\n\n    container = Docker::Container.get(user.tailscale_container_id)\n    running = container.json.dig(\"State\", \"Running\")\n\n    ts_sandboxes = user.sandboxes.active.where(tailscale: true)\n    sandbox_ips = ts_sandboxes.map do |sb|\n      ip = sandbox_tailscale_ip(sandbox: sb)\n      { name: sb.name, ip: ip }\n    end\n\n    result = {\n      running: running,\n      container_id: user.tailscale_container_id[0..11],\n      network: user.tailscale_network,\n      connected_sandboxes: ts_sandboxes.count,\n      sandboxes: sandbox_ips\n    }\n\n    if running\n      ip_out = container.exec([ \"tailscale\", \"ip\", \"--4\" ])\n      result[:tailscale_ip] = ip_out.first.first&.strip if ip_out.first.any?\n\n      status_out