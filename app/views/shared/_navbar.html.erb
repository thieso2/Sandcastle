<%
  nav_items = [
    { label: "Dashboard", path: main_app.root_path, active: controller_name == "dashboard" && !controller_path.start_with?("admin") },
    { label: "Guide", path: main_app.guide_path, active: controller_name == "pages" },
    { label: "Tailscale", path: main_app.tailscale_path, active: controller_name == "tailscale" && !controller_path.start_with?("api") },
  ]
  show_admin = policy(:user).index?
  unresolved_errors = (show_admin ? (SolidErrors::Error.unresolved.count rescue 0) : 0)
%>
<nav class="fixed top-8 inset-x-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
  <details class="group max-w-6xl mx-auto px-4">
    <summary class="h-14 flex items-center justify-between cursor-pointer list-none [&::-webkit-details-marker]:hidden">
      <%# Brand %>
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-amber-500">
          <path d="M19.006 3.705a.75.75 0 1 0-.512-1.41L6 6.838V3a.75.75 0 0 0-.75-.75h-1.5A.75.75 0 0 0 3 3v4.93l-1.006.365a.75.75 0 0 0 .512 1.41l16.5-6A.75.75 0 0 0 19.006 3.705Z" />
          <path fill-rule="evenodd" d="M3.019 11.114 18 5.667V9.56l4.759 1.653a.75.75 0 0 1-.518 1.407l-.241-.084v8.214a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1-.75-.75v-9.636Zm12.75 8.136v-3.75h-3v3.75h3Zm-4.5 0v-3.75h-3v3.75h3ZM6.269 12v7.25h-.769v-6.5l8.769-3.052V12H6.27Z" clip-rule="evenodd" />
        </svg>
        <span class="text-lg font-bold text-gray-900">Sandcastle</span>
        <% if show_admin && unresolved_errors > 0 %>
          <span class="md:hidden inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 rounded-full text-xs font-semibold bg-red-500 text-white"><%= unresolved_errors %></span>
        <% end %>
      <% end %>

      <%# Desktop nav %>
      <div class="hidden md:flex items-center gap-1">
        <% nav_items.each do |item| %>
          <%= link_to item[:label], item[:path],
                class: "px-3 py-1.5 rounded-md text-sm font-medium transition-colors #{
                  item[:active] ? 'bg-gray-900 text-white' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'
                }" %>
        <% end %>

        <% if show_admin %>
          <%= link_to main_app.admin_dashboard_path,
                class: "px-3 py-1.5 rounded-md text-sm font-medium transition-colors inline-flex items-center gap-1.5 #{
                  controller_path.start_with?('admin') ? 'bg-gray-900 text-white' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'
                }" do %>
            Admin
            <% if unresolved_errors > 0 %>
              <span class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 rounded-full text-xs font-semibold bg-red-500 text-white"><%= unresolved_errors %></span>
            <% end %>
          <% end %>
        <% end %>

        <span class="mx-2 h-5 w-px bg-gray-200"></span>

        <%= link_to Current.user.name, main_app.settings_path,
              class: "text-sm text-gray-500 hover:text-gray-700 font-medium" %>
        <%= link_to main_app.settings_path, class: "text-sm text-gray-400 hover:text-gray-600 inline-flex items-center gap-1" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M7.84 1.804A1 1 0 0 1 8.82 1h2.36a1 1 0 0 1 .98.804l.331 1.652a6.993 6.993 0 0 1 1.929 1.115l1.598-.54a1 1 0 0 1 1.186.447l1.18 2.044a1 1 0 0 1-.205 1.251l-1.267 1.113a7.047 7.047 0 0 1 0 2.228l1.267 1.113a1 1 0 0 1 .206 1.25l-1.18 2.045a1 1 0 0 1-1.187.447l-1.598-.54a6.993 6.993 0 0 1-1.929 1.115l-.33 1.652a1 1 0 0 1-.98.804H8.82a1 1 0 0 1-.98-.804l-.331-1.652a6.993 6.993 0 0 1-1.929-1.115l-1.598.54a1 1 0 0 1-1.186-.447l-1.18-2.044a1 1 0 0 1 .205-1.251l1.267-1.114a7.05 7.05 0 0 1 0-2.227L1.821 7.773a1 1 0 0 1-.206-1.25l1.18-2.045a1 1 0 0 1 1.187-.447l1.598.54A6.992 6.992 0 0 1 7.51 3.456l.33-1.652ZM10 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
          </svg>
          Settings
        <% end %>
        <%= button_to main_app.session_path, method: :delete,
              class: "text-sm text-gray-400 hover:text-gray-600 inline-flex items-center gap-1" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M3 4.25A2.25 2.25 0 0 1 5.25 2h5.5A2.25 2.25 0 0 1 13 4.25v2a.75.75 0 0 1-1.5 0v-2a.75.75 0 0 0-.75-.75h-5.5a.75.75 0 0 0-.75.75v11.5c0 .414.336.75.75.75h5.5a.75.75 0 0 0 .75-.75v-2a.75.75 0 0 1 1.5 0v2A2.25 2.25 0 0 1 10.75 18h-5.5A2.25 2.25 0 0 1 3 15.75V4.25Z" clip-rule="evenodd" />
            <path fill-rule="evenodd" d="M19 10a.75.75 0 0 0-.75-.75H8.704l1.048-.943a.75.75 0 1 0-1.004-1.114l-2.5 2.25a.75.75 0 0 0 0 1.114l2.5 2.25a.75.75 0 1 0 1.004-1.114l-1.048-.943h9.546A.75.75 0 0 0 19 10Z" clip-rule="evenodd" />
          </svg>
          Log out
        <% end %>
      </div>

      <%# Mobile hamburger (toggles the <details> below) %>
      <span class="md:hidden inline-flex items-center justify-center w-10 h-10 -mr-2 rounded-md text-gray-600 hover:bg-gray-100" aria-label="Toggle menu">
        <svg class="w-6 h-6 group-open:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg class="w-6 h-6 hidden group-open:inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </span>
    </summary>

    <%# Mobile menu panel %>
    <div class="md:hidden -mx-4 px-4 pb-3 pt-1 space-y-1 border-t border-gray-200 bg-white shadow-lg">
      <% nav_items.each do |item| %>
        <%= link_to item[:label], item[:path],
              class: "block px-3 py-2 rounded-md text-sm font-medium #{
                item[:active] ? 'bg-gray-900 text-white' : 'text-gray-700 hover:bg-gray-100'
              }" %>
      <% end %>
      <% if show_admin %>
        <%= link_to main_app.admin_dashboard_path,
              class: "flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium #{
                controller_path.start_with?('admin') ? 'bg-gray-900 text-white' : 'text-gray-700 hover:bg-gray-100'
              }" do %>
          <span>Admin</span>
          <% if unresolved_errors > 0 %>
            <span class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 rounded-full text-xs font-semibold bg-red-500 text-white"><%= unresolved_errors %></span>
          <% end %>
        <% end %>
      <% end %>
      <div class="h-px bg-gray-200 my-1"></div>
      <%= link_to main_app.settings_path, class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-100" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-gray-400">
          <path fill-rule="evenodd" d="M7.84 1.804A1 1 0 0 1 8.82 1h2.36a1 1 0 0 1 .98.804l.331 1.652a6.993 6.993 0 0 1 1.929 1.115l1.598-.54a1 1 0 0 1 1.186.447l1.18 2.044a1 1 0 0 1-.205 1.251l-1.267 1.113a7.047 7.047 0 0 1 0 2.228l1.267 1.113a1 1 0 0 1 .206 1.25l-1.18 2.045a1 1 0 0 1-1.187.447l-1.598-.54a6.993 6.993 0 0 1-1.929 1.115l-.33 1.652a1 1 0 0 1-.98.804H8.82a1 1 0 0 1-.98-.804l-.331-1.652a6.993 6.993 0 0 1-1.929-1.115l-1.598.54a1 1 0 0 1-1.186-.447l-1.18-2.044a1 1 0 0 1 .205-1.251l1.267-1.114a7.05 7.05 0 0 1 0-2.227L1.821 7.773a1 1 0 0 1-.206-1.25l1.18-2.045a1 1 0 0 1 1.187-.447l1.598.54A6.992 6.992 0 0 1 7.51 3.456l.33-1.652ZM10 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
        </svg>
        <span class="font-medium"><%= Current.user.name %></span>
        <span class="text-gray-400">· Settings</span>
      <% end %>
      <%= button_to main_app.session_path, method: :delete,
            class: "w-full flex items-center gap-2 px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-100" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-gray-400">
          <path fill-rule="evenodd" d="M3 4.25A2.25 2.25 0 0 1 5.25 2h5.5A2.25 2.25 0 0 1 13 4.25v2a.75.75 0 0 1-1.5 0v-2a.75.75 0 0 0-.75-.75h-5.5a.75.75 0 0 0-.75.75v11.5c0 .414.336.75.75.75h5.5a.75.75 0 0 0 .75-.75v-2a.75.75 0 0 1 1.5 0v2A2.25 2.25 0 0 1 10.75 18h-5.5A2.25 2.25 0 0 1 3 15.75V4.25Z" clip-rule="evenodd" />
          <path fill-rule="evenodd" d="M19 10a.75.75 0 0 0-.75-.75H8.704l1.048-.943a.75.75 0 1 0-1.004-1.114l-2.5 2.25a.75.75 0 0 0 0 1.114l2.5 2.25a.75.75 0 1 0 1.004-1.114l-1.048-.943h9.546A.75.75 0 0 0 19 10Z" clip-rule="evenodd" />
        </svg>
        <span>Log out</span>
      <% end %>
    </div>
  </details>
</nav>
