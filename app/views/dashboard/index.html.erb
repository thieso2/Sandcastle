<div class="max-w-6xl mx-auto px-4 py-8">
  <%# Subscribe to user's personal dashboard stream %>
  <%= turbo_stream_from [Current.user, "dashboard"] %>

  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">My Sandcastles</h1>
      <p class="text-gray-500 mt-1">Manage your development environments</p>
    </div>
    <%= link_to new_sandbox_path,
          class: "inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-200 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
        <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
      </svg>
      Create Sandcastle
    <% end %>
  </div>

  <%# Active sandboxes. The empty state is a sibling, hidden via CSS when
      #sandboxes has at least one child so Turbo Stream removes reveal it
      without a page reload. %>
  <div id="sandboxes" class="space-y-4">
    <% @sandboxes.each do |sandbox| %>
      <%= render "sandbox", sandbox: sandbox, vnc_active: @vnc_active_ids.include?(sandbox.id), tailscale_ip: @tailscale_ips[sandbox.id] %>
    <% end %>
  </div>

  <div id="sandboxes-empty" class="text-center py-12 bg-white rounded-lg border border-gray-200">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 mx-auto text-gray-400 mb-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
    </svg>
    <p class="text-gray-600 font-medium mb-2">No sandcastles yet</p>
    <p class="text-sm text-gray-500">Get started by creating your first development environment</p>
  </div>

  <%# Archived section is always in the DOM so Turbo Stream append/remove
      can update it live. Hidden via CSS when empty. Count is a child span
      so it can be re-rendered independently. %>
  <% archived_sandboxes = @archived_sandboxes.to_a %>
  <div id="archived-section" class="mt-10">
    <details class="group">
      <summary class="flex items-center gap-2 cursor-pointer text-gray-500 hover:text-gray-700 mb-3 list-none">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 group-open:rotate-90 transition-transform">
          <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm font-medium">Archived</span>
        <span class="text-xs text-gray-400">— will be purged after retention window expires</span>
      </summary>

      <div id="archived-sandboxes" class="space-y-3 mt-3">
        <% archived_sandboxes.each do |sandbox| %>
          <%= render "dashboard/archived_sandbox", sandbox: sandbox %>
        <% end %>
      </div>
    </details>
  </div>
</div>

<%# Show the empty state only when #sandboxes has no children, and hide the
    archived section when its inner list is empty. :has() is supported in
    every evergreen browser (Chrome 105+, Safari 15.4+, Firefox 121+). %>
<style>
  #sandboxes:has(> *) ~ #sandboxes-empty { display: none; }
  #archived-section:not(:has(#archived-sandboxes > *)) { display: none; }
</style>
