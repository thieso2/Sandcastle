<div class="max-w-6xl mx-auto px-4 py-8">
  <%= turbo_frame_tag "system_status", src: admin_system_status_path, loading: :lazy do %>
    <div class="bg-gray-50 rounded-lg p-4 mb-8 border border-gray-200 animate-pulse">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">System Status</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
        <% 4.times do %>
          <div>
            <span class="block h-4 w-16 bg-gray-200 rounded mb-1"></span>
            <span class="block h-5 w-24 bg-gray-200 rounded"></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-gray-900">All Sandcastles</h2>
    </div>

    <% if @sandboxes.any? %>
      <div class="grid gap-4">
        <% @sandboxes.each do |sandbox| %>
          <%= render "sandbox", sandbox: sandbox %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
        <p class="text-gray-500">No sandcastles yet.</p>
      </div>
    <% end %>
  </div>

  <% if @archived_sandboxes.any? %>
    <div class="mb-8">
      <details class="group">
        <summary class="flex items-center gap-2 cursor-pointer text-gray-500 hover:text-gray-700 mb-4 list-none">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 group-open:rotate-90 transition-transform">
            <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
          <span class="text-base font-semibold text-gray-700">Archived Sandcastles (<%= @archived_sandboxes.count %>)</span>
        </summary>

        <div class="grid gap-3 mt-3">
          <% @archived_sandboxes.each do |sandbox| %>
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-4 flex items-center justify-between gap-4">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="inline-block w-2.5 h-2.5 rounded-full bg-gray-400"></span>
                <span class="font-mono font-medium text-gray-700"><%= sandbox.name %></span>
                <span class="text-xs text-gray-500 bg-gray-200 px-2 py-0.5 rounded"><%= sandbox.user.name %></span>
                <% if sandbox.archived_at %>
                  <span class="text-xs text-gray-500">Archived <%= time_ago_in_words(sandbox.archived_at) %> ago</span>
                  <% retention = sandbox.user.effective_archive_retention_days %>
                  <% expires_at = sandbox.archived_at + retention.days %>
                  <span class="text-xs <%= expires_at < Time.current ? 'text-red-500' : 'text-gray-400' %>">
                    Expires <%= time_ago_in_words(expires_at) %> <%= expires_at > Time.current ? "from now" : "ago (pending purge)" %>
                  </span>
                <% end %>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <%= button_to "Restore", archive_restore_admin_sandbox_path(sandbox), method: :post,
                      class: "text-xs px-3 py-1.5 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors" %>
                <div data-controller="inline-confirm" class="inline-block">
                  <%= button_to "Purge", purge_admin_sandbox_path(sandbox), method: :delete,
                        class: "text-xs px-3 py-1.5 bg-red-600 text-white rounded hover:bg-red-700 transition-colors",
                        data: {
                          action: "click->inline-confirm#confirm",
                          confirm_message: "Purge? (data permanently deleted)"
                        } %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </details>
    </div>
  <% end %>

  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-gray-900">Users</h2>
      <%= link_to "Manage Users", admin_users_path, class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
    </div>

    <div class="overflow-hidden rounded-lg border border-gray-200">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sandcastles</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">SSH Key</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @users.each do |user| %>
            <tr>
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <%= user.name %><%= " (admin)" if user.admin? %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= user.sandboxes.active.count %></td>
              <td class="px-4 py-3 text-sm text-gray-500">
                <% if user.ssh_public_key.present? %>
                  <span class="text-green-600">Yes</span>
                <% else %>
                  <span class="text-gray-400">No</span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                  <%= user.active? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                  <%= user.status %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
