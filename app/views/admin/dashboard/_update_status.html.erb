<%= turbo_frame_tag "update_status" do %>
  <div class="bg-gray-50 rounded-lg p-4 mb-8 border border-gray-200"
       data-controller="update-check"
       data-update-check-check-url-value="<%= check_admin_update_path %>"
       data-update-check-pull-url-value="<%= pull_admin_update_path %>"
       data-update-check-status-url-value="<%= status_admin_update_path %>"
       data-update-check-restart-url-value="<%= restart_admin_update_path %>"
       data-update-check-progress-url-value="<%= progress_admin_update_path %>">

    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">System Update</h2>
      <button data-action="click->update-check#checkForUpdates"
              data-update-check-target="checkBtn"
              class="text-xs px-3 py-1 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 transition-colors">
        Check for Updates
      </button>
    </div>

    <% any_update = false %>
    <% app = @update_info[:app] || {} %>
    <% sandbox_img = @update_info[:sandbox] || {} %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
      <%# App image %>
      <div>
        <span class="text-gray-500">App Image</span>
        <% if app[:error] %>
          <p class="font-mono font-medium text-gray-400">Error: <%= app[:error] %></p>
        <% else %>
          <div class="mt-0.5">
            <div class="flex items-center gap-2">
              <p class="font-mono font-medium">
                <%= app[:local_version] || "unknown" %>
              </p>
              <% if app[:update_available] %>
                <% any_update = true %>
                <span class="inline-flex items-center gap-1 text-xs font-medium text-amber-700 bg-amber-100 px-1.5 py-0.5 rounded">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                    <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
                  </svg>
                  <%= app[:remote_version] || "new" %> available
                </span>
              <% elsif app[:local_digest].present? && app[:remote_digest].present? %>
                <span class="text-xs text-green-600 font-medium">Up to date</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Sandbox image %>
      <div>
        <span class="text-gray-500">Sandbox Image</span>
        <% if sandbox_img[:error] %>
          <p class="font-mono font-medium text-gray-400">Error: <%= sandbox_img[:error] %></p>
        <% else %>
          <div class="mt-0.5">
            <div class="flex items-center gap-2">
              <p class="font-mono font-medium">
                <%= sandbox_img[:local_version] || "unknown" %>
              </p>
              <% if sandbox_img[:update_available] %>
                <% any_update = true %>
                <span class="inline-flex items-center gap-1 text-xs font-medium text-amber-700 bg-amber-100 px-1.5 py-0.5 rounded">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                    <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
                  </svg>
                  <%= sandbox_img[:remote_version] || "new" %> available
                </span>
              <% elsif sandbox_img[:local_digest].present? && sandbox_img[:remote_digest].present? %>
                <span class="text-xs text-green-600 font-medium">Up to date</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <% if any_update %>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <% if app[:update_available] && sandbox_img[:update_available] %>
          <button data-action="click->update-check#startPull"
                  data-update-target="all"
                  class="text-xs px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors">
            Update All
          </button>
        <% end %>
        <% if app[:update_available] %>
          <button data-action="click->update-check#startPull"
                  data-update-target="app"
                  class="text-xs px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors">
            Update App
          </button>
        <% end %>
        <% if sandbox_img[:update_available] %>
          <button data-action="click->update-check#startPull"
                  data-update-target="sandbox"
                  class="text-xs px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors">
            Update Sandbox Image
          </button>
        <% end %>
      </div>
    <% end %>

    <%# Restart pending banner %>
    <% if @update_info[:restart_pending] %>
      <div class="mt-3 p-3 bg-orange-50 border border-orange-200 rounded text-sm text-orange-800">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0 text-orange-500">
            <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H4.598a.75.75 0 0 0-.75.75v3.634a.75.75 0 0 0 1.5 0v-2.033l.312.311a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm-9.624-2.848a.75.75 0 0 0 1.45.388A5.5 5.5 0 0 1 16.39 11.5l.311.31h-2.432a.75.75 0 0 0 0 1.5h3.633a.75.75 0 0 0 .75-.75V8.927a.75.75 0 0 0-1.5 0v2.033l-.31-.311A7 7 0 0 0 5.688 8.576Z" clip-rule="evenodd" />
          </svg>
          <span class="font-medium">A newer app image is ready.</span>
          <button data-action="click->update-check#restartNow"
                  data-update-check-target="restartBtn"
                  class="ml-auto text-xs px-3 py-1 bg-orange-600 text-white rounded hover:bg-orange-700 transition-colors font-medium">
            Restart Now
          </button>
        </div>
      </div>
    <% end %>

    <% if @update_info[:checked_at] %>
      <p class="text-xs text-gray-400 mt-3">Last checked: <%= time_ago_in_words(@update_info[:checked_at]) %> ago</p>
    <% end %>

    <%# Pull progress (shown during image pull) %>
    <div data-update-check-target="pullProgress" class="hidden mt-3 p-3 bg-blue-50 border border-blue-200 rounded text-sm text-blue-700">
      <div class="flex items-center gap-2">
        <svg data-update-check-target="pullSpinner" class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span data-update-check-target="pullStatus">Pulling images…</span>
        <button data-action="click->update-check#restartNow"
                data-update-check-target="restartBtn"
                class="hidden ml-auto text-xs px-3 py-1 bg-orange-600 text-white rounded hover:bg-orange-700 transition-colors font-medium">
          Restart Now
        </button>
      </div>
    </div>
  </div>
<% end %>
