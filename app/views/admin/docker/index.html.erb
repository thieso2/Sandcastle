<div class="max-w-6xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Docker</h1>

  <%# ── Docker daemon info ── %>
  <div class="bg-white border border-gray-200 rounded-lg p-4 mb-6">
    <% begin %>
      <% info = Docker.info %>
      <% version = Docker.version %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
        <div>
          <span class="text-gray-500 block">Version</span>
          <span class="font-mono font-medium"><%= version["Version"] %></span>
        </div>
        <div>
          <span class="text-gray-500 block">API Version</span>
          <span class="font-mono font-medium"><%= version["ApiVersion"] %></span>
        </div>
        <div>
          <span class="text-gray-500 block">Containers</span>
          <span class="font-mono font-medium"><%= info["ContainersRunning"] %> running / <%= info["Containers"] %> total</span>
        </div>
        <div>
          <span class="text-gray-500 block">Images</span>
          <span class="font-mono font-medium"><%= info["Images"] %></span>
        </div>
        <div>
          <span class="text-gray-500 block">Storage Driver</span>
          <span class="font-mono font-medium"><%= info["Driver"] %></span>
        </div>
        <div>
          <span class="text-gray-500 block">Runtimes</span>
          <span class="font-mono font-medium"><%= info["Runtimes"]&.keys&.join(", ") %></span>
        </div>
        <div>
          <span class="text-gray-500 block">OS / Arch</span>
          <span class="font-mono font-medium"><%= info["OperatingSystem"] %> (<%= info["Architecture"] %>)</span>
        </div>
        <div>
          <span class="text-gray-500 block">Docker Root</span>
          <span class="font-mono font-medium"><%= info["DockerRootDir"] %></span>
        </div>
      </div>
    <% rescue Docker::Error::DockerError => e %>
      <p class="text-red-600 text-sm">Failed to connect to Docker: <%= e.message %></p>
    <% end %>
  </div>

  <%# ── Service tabs ── %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="border-b border-gray-200 flex" id="service-tabs">
      <% @containers.each_with_index do |c, i| %>
        <button type="button"
                data-container="<%= c[:name] %>"
                onclick="selectTab(this)"
                class="service-tab relative px-5 py-3 text-sm font-medium transition-colors
                       <%= i == 0 ? 'text-blue-600 border-b-2 border-blue-600' : 'text-gray-500 hover:text-gray-700' %>">
          <span class="inline-block w-2 h-2 rounded-full mr-1.5 <%= c[:exists] && c[:state] == 'running' ? 'bg-green-500' : 'bg-red-500' %>"></span>
          <%= c[:name].delete_prefix("sandcastle-").delete_suffix("-1") %>
          <% if c[:exists] %>
            <span class="ml-1 text-xs text-gray-400 font-normal"><%= c[:status] %></span>
          <% end %>
        </button>
      <% end %>
    </div>

    <%# ── Log panel (shared, full width) ── %>
    <div class="p-4">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-3">
          <span class="text-sm text-gray-500">Showing last <span id="log-line-count">200</span> lines</span>
          <label class="inline-flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
            <input type="checkbox" id="follow-log" checked
                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                   onchange="toggleFollow()">
            Follow
          </label>
        </div>
        <div class="flex items-center gap-2">
          <select id="tail-select" onchange="reloadCurrentLogs()"
                  class="text-xs border border-gray-300 rounded px-2 py-1 bg-white">
            <option value="100">100 lines</option>
            <option value="200" selected>200 lines</option>
            <option value="500">500 lines</option>
            <option value="1000">1000 lines</option>
          </select>
          <button type="button" onclick="reloadCurrentLogs()"
                  class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded hover:bg-gray-200">
            Refresh
          </button>
        </div>
      </div>
      <pre id="log-output" class="bg-gray-900 text-gray-100 text-xs rounded p-4 overflow-x-auto overflow-y-auto font-mono whitespace-pre-wrap" style="height: 28rem;"></pre>
    </div>
  </div>
</div>

<script>
  var currentContainer = "<%= @containers.first&.dig(:name) %>";
  var tailInterval = null;
  var userScrolling = false;

  var logOutput = document.getElementById("log-output");

  // Detect manual scroll — disable follow when user scrolls up
  logOutput.addEventListener("scroll", function() {
    var atBottom = logOutput.scrollHeight - logOutput.scrollTop - logOutput.clientHeight < 20;
    if (!atBottom && !userScrolling) {
      userScrolling = true;
      setFollow(false);
    } else if (atBottom && userScrolling) {
      userScrolling = false;
    }
  });

  function isFollowing() {
    return document.getElementById("follow-log").checked;
  }

  function setFollow(val) {
    document.getElementById("follow-log").checked = val;
    toggleFollow();
  }

  function selectTab(button) {
    document.querySelectorAll(".service-tab").forEach(function(tab) {
      tab.classList.remove("text-blue-600", "border-b-2", "border-blue-600");
      tab.classList.add("text-gray-500");
    });
    button.classList.remove("text-gray-500");
    button.classList.add("text-blue-600", "border-b-2", "border-blue-600");

    currentContainer = button.dataset.container;
    userScrolling = false;
    setFollow(true);
    loadLogs(currentContainer);
  }

  function reloadCurrentLogs() {
    loadLogs(currentContainer);
  }

  function loadLogs(name) {
    var tail = document.getElementById("tail-select").value;
    var output = logOutput;
    var countSpan = document.getElementById("log-line-count");
    countSpan.textContent = tail;

    fetch("/admin/docker/" + encodeURIComponent(name) + "/logs?tail=" + tail, {
      headers: { "Accept": "application/json" }
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) {
          output.textContent = "Error: " + data.error;
        } else {
          output.textContent = data.lines.join("\n");
          if (isFollowing()) {
            output.scrollTop = output.scrollHeight;
          }
        }
      })
      .catch(function(e) {
        output.textContent = "Failed to fetch logs: " + e.message;
      });
  }

  function toggleFollow() {
    if (isFollowing()) {
      userScrolling = false;
      logOutput.scrollTop = logOutput.scrollHeight;
      startAutoTail();
    } else {
      stopAutoTail();
    }
  }

  function startAutoTail() {
    stopAutoTail();
    tailInterval = setInterval(function() {
      loadLogs(currentContainer);
    }, 3000);
  }

  function stopAutoTail() {
    if (tailInterval) {
      clearInterval(tailInterval);
      tailInterval = null;
    }
  }

  // Load first tab on page load and start auto-tail
  if (currentContainer) {
    loadLogs(currentContainer);
    startAutoTail();
  }

  // Stop polling when leaving the page
  document.addEventListener("turbo:before-cache", stopAutoTail);
  document.addEventListener("turbo:before-visit", stopAutoTail);
</script>
