<% content_for(:title) { "#{@sandbox.name} — Terminal" } %>

<% if @emulator == "xterm" %>
  <div id="terminal-container"
       data-controller="xterm-terminal"
       data-xterm-terminal-ws-url-value="<%= @ws_url %>"
       data-xterm-terminal-token-url-value="<%= @token_url %>">
  </div>
<% else %>
  <div id="terminal-container"
       data-controller="ghostty-terminal"
       data-ghostty-terminal-ws-url-value="<%= @ws_url %>"
       data-ghostty-terminal-token-url-value="<%= @token_url %>">
  </div>
<% end %>
