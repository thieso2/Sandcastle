<% content_for(:title) { "Create Sandcastle" } %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Create Sandcastle</h1>
    <p class="text-gray-500 mt-1">Configure and create a new sandbox environment</p>
  </div>

  <%= form_with url: sandboxes_path, method: :post, class: "space-y-6" do |form| %>
    <%# Basic Information %>
    <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">Basic Information</h2>

      <div>
        <%= form.label :name, "Sandbox Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name,
              required: true,
              pattern: "[a-z][a-z0-9_\\-]*",
              maxlength: 63,
              placeholder: "",
              id: "sandbox_name",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-xs text-gray-500">Lowercase letters, numbers, hyphens, and underscores only</p>
      </div>

      <div>
        <%= form.label :image, "Container Image", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :image,
              placeholder: "ghcr.io/thieso2/sandcastle-sandbox:latest",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-xs text-gray-500">Leave empty to use the default image</p>
      </div>
    </div>

    <%# Restore from Snapshot %>
    <% if @snapshots.any? %>
      <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
        <h2 class="text-lg font-semibold text-gray-900">Restore from Snapshot</h2>

        <div>
          <%= form.label :snapshot, "Snapshot", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :snapshot,
                options_for_select(
                  [["None (fresh sandbox)", ""]] +
                  @snapshots.map { |s|
                    label = s[:name]
                    label += " — #{s[:label]}" if s[:label].present?
                    label += " [#{s[:layers].join(', ')}]" if s[:layers].present?
                    label += " (from #{s[:source_sandbox]})" if s[:source_sandbox].present?
                    [label, s[:name]]
                  },
                  params[:snapshot]
                ),
                {},
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          <p class="mt-1 text-xs text-gray-500">
            Create a new sandbox from an existing snapshot.
            <% unless @btrfs_available %>
              (Only container layer available — BTRFS not detected)
            <% end %>
          </p>
        </div>
      </div>
    <% end %>

    <%# Storage Options %>
    <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">Storage Options</h2>

      <div class="flex items-center justify-between gap-3">
        <div class="flex-1">
          <%= form.label :project_id, "Project Preset", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :project_id,
                options_for_select([["Default Project", ""]] + @projects.reject(&:default_project?).map { |project| ["#{project.name} (#{project.path})", project.id] }),
                {},
                id: "sandbox_project_id",
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          <p class="mt-1 text-xs text-gray-500">Pick a saved project to reuse its scoped home/data path and all sandbox defaults.</p>
        </div>
        <div class="pt-6">
          <%= link_to "New Project", new_project_path(return_to: new_sandbox_path), class: "inline-flex px-3 py-2 text-sm bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200" %>
        </div>
      </div>

      <div>
        <%= form.label :project_path, "Project Subdir", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :project_path,
              placeholder: "e.g., projects/myapp",
              id: "sandbox_project_path",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-xs text-gray-500">Creates a project-scoped sandbox by mounting this subdir as both <code class="bg-gray-100 px-1 rounded font-mono">$HOME</code> and <code class="bg-gray-100 px-1 rounded font-mono">/persisted</code>.</p>
      </div>

      <div class="space-y-3">
        <label class="flex items-start gap-3 cursor-pointer">
          <%= form.check_box :mount_home, checked: @defaults.mount_home, id: "sandbox_mount_home", class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
          <div class="flex-1">
            <div class="text-sm font-medium text-gray-900">Mount persistent home directory</div>
            <p class="text-xs text-gray-500">Your home directory (~/) will persist across all sandboxes</p>
          </div>
        </label>

        <div id="home_path_row">
          <%= form.label :home_path, "Home Subdir (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :home_path,
                value: @defaults.home_path,
                placeholder: "e.g., projects/myapp",
                id: "sandbox_home_path",
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          <p class="mt-1 text-xs text-gray-500">Mount only this subdir of your persisted home as <code class="bg-gray-100 px-1 rounded font-mono">$HOME</code>. Leave empty to disable.</p>
        </div>

        <label class="flex items-start gap-3 cursor-pointer">
          <%= form.check_box :mount_data, id: "sandbox_mount_data", checked: @defaults.data_path.present?,
                class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
          <div class="flex-1">
            <div class="text-sm font-medium text-gray-900">Mount /persisted</div>
            <p class="text-xs text-gray-500">Mount a persistent data volume at /persisted in the sandbox</p>
          </div>
        </label>

        <div id="data_path_row">
          <%= form.label :data_path, "Data Subpath (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :data_path,
                value: @defaults.data_path.presence&.then { |p| p == "." ? "" : p },
                placeholder: "e.g., projects/myapp",
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          <p class="mt-1 text-xs text-gray-500">Leave empty for the root data directory, or specify a subpath</p>
        </div>

        <div>
          <%= form.label :storage_mode, "Write Behavior", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <% storage_options = [
               [ "Write directly to persistent storage", "direct" ],
               @btrfs_available ?
                 [ "Review changes before committing", "snapshot" ] :
                 [ "Review changes before committing", "snapshot", { disabled: true } ]
             ] %>
          <%= form.select :storage_mode,
                options_for_select(storage_options, "direct"),
                {},
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          <p class="mt-1 text-xs text-gray-500">
            Direct writes update the master copy immediately.
            <% if @btrfs_available %>
              Review mode will use a writable snapshot branch for mounted storage.
            <% else %>
              Review mode requires BTRFS support on the data filesystem.
            <% end %>
          </p>
        </div>
      </div>
    </div>

    <%# Network Options %>
    <% if Current.user.tailscale_enabled? %>
      <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
        <h2 class="text-lg font-semibold text-gray-900">Network Options</h2>

        <label class="flex items-start gap-3 cursor-pointer">
          <%= form.check_box :tailscale, checked: true, class: "mt-1 h-4 w-4 text-purple-600 border-gray-300 rounded focus:ring-purple-500" %>
          <div class="flex-1">
            <div class="text-sm font-medium text-gray-900">Connect to Tailscale network</div>
            <p class="text-xs text-gray-500">Automatically connect this sandbox to your Tailscale network</p>
          </div>
        </label>
      </div>
    <% end %>

    <%# Services %>
    <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">Services</h2>

      <label class="flex items-start gap-3 cursor-pointer">
        <%= form.check_box :docker_enabled, checked: @defaults.docker_enabled,
              class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Start Docker daemon</div>
          <p class="text-xs text-gray-500">Enable Docker-in-Docker support inside the sandbox</p>
        </div>
      </label>

      <label class="flex items-start gap-3 cursor-pointer">
        <%= form.check_box :oidc_enabled, checked: @defaults.oidc_enabled,
              class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Enable OIDC identity tokens</div>
          <p class="text-xs text-gray-500">Allow this sandbox to mint short-lived tokens for cloud workload federation</p>
        </div>
      </label>

      <div class="ml-7 space-y-3 border-l border-gray-100 pl-4">
        <label class="flex items-start gap-3 cursor-pointer">
          <%= form.check_box :gcp_oidc_enabled,
                checked: @defaults.gcp_oidc_enabled,
                class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
          <div class="flex-1">
            <div class="text-sm font-medium text-gray-900">Configure GCP credentials</div>
            <p class="text-xs text-gray-500">Write Google external account credentials automatically when this sandbox starts</p>
          </div>
        </label>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="md:col-span-2">
            <%= form.label :gcp_oidc_config_id, "GCP identity config", class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= form.select :gcp_oidc_config_id,
                  options_for_select([["None", ""]] + @gcp_oidc_configs.map { |config| [config.name, config.id] }, @defaults.gcp_oidc_config_id),
                  {},
                  class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div class="md:col-span-2">
            <%= form.label :gcp_service_account_email, "Custom service account override", class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= form.email_field :gcp_service_account_email,
                  value: @defaults.gcp_service_account_email,
                  placeholder: "Leave blank for the config default",
                  class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <p class="mt-1 text-xs text-gray-500">Leave blank to use the selected config's default read-only Sandcastle service account.</p>
          </div>
          <div>
            <%= form.label :gcp_principal_scope, "Principal scope", class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= form.select :gcp_principal_scope,
                  options_for_select([["All my sandboxes", "user"], ["This sandbox", "sandbox"]], @defaults.gcp_principal_scope),
                  {},
                  class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <%= label_tag :gcp_roles_text, "Project roles", class: "block text-xs font-medium text-gray-600 mb-1" %>
            <%= text_field_tag :gcp_roles_text, @defaults.gcp_roles_list.join(", "),
                  placeholder: "roles/viewer, roles/storage.objectViewer",
                  class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>

        <% if @gcp_oidc_configs.empty? %>
          <p class="text-xs text-amber-700">Add a GCP Identity Config in Settings before starting this sandbox.</p>
        <% end %>
      </div>

      <label class="flex items-start gap-3 cursor-pointer">
        <%= form.check_box :ssh_start_tmux, checked: @defaults.ssh_start_tmux,
              class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Start tmux on SSH login</div>
          <p class="text-xs text-gray-500">Automatically attach to a shared tmux session when you SSH in</p>
        </div>
      </label>

      <label class="flex items-start gap-3 cursor-pointer">
        <%= form.check_box :vnc_enabled, checked: @defaults.vnc_enabled,
              id: "sandbox_vnc_enabled",
              class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Enable VNC display</div>
          <p class="text-xs text-gray-500">Start a virtual display (Xvnc) for GUI apps and browser access</p>
        </div>
      </label>

      <% smb_ready = Current.user.tailscale_enabled? && Current.user.smb_password.present? %>
      <label class="flex items-start gap-3 <%= smb_ready ? 'cursor-pointer' : 'opacity-50' %>">
        <%= form.check_box :smb_enabled,
              checked: smb_ready && @defaults.smb_enabled,
              disabled: !smb_ready,
              title: smb_ready ? nil : "Requires Tailscale enabled and an SMB password set in Settings",
              class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
        <div class="flex-1">
          <div class="text-sm font-medium text-gray-900">Enable SMB file sharing</div>
          <% if smb_ready %>
            <p class="text-xs text-gray-500">Mount home/persisted as a network drive via SMB3</p>
          <% else %>
            <p class="text-xs text-gray-500">
              Requires Tailscale enabled and an SMB password —
              <%= link_to "configure in Settings", settings_path, class: "text-blue-600 hover:underline" %>
            </p>
          <% end %>
        </div>
      </label>

      <div id="vnc_options_row" class="space-y-4">
        <div>
          <%= form.label :vnc_geometry, "Screen Resolution", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :vnc_geometry,
                options_for_select([
                  ["1280×900 (default)", "1280x900"],
                  ["1366×768", "1366x768"],
                  ["1440×900", "1440x900"],
                  ["1600×900", "1600x900"],
                  ["1920×1080 (Full HD)", "1920x1080"],
                  ["2560×1440 (2K)", "2560x1440"]
                ], "1280x900"),
                {},
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= form.label :vnc_depth, "Color Depth", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :vnc_depth,
                options_for_select([
                  ["24-bit (default)", 24],
                  ["32-bit", 32],
                  ["16-bit", 16],
                  ["8-bit", 8]
                ], 24),
                {},
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
      </div>
    </div>

    <%# Actions %>
    <div class="flex items-center justify-between pt-4">
      <%= link_to "Cancel", root_path, class: "text-gray-600 hover:text-gray-900" %>
      <%= form.submit "Create Sandcastle", class: "px-6 py-2.5 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-200" %>
    </div>
  <% end %>
</div>

<script>
(function() {
  var adjectives = ["swift", "brave", "wild", "calm", "bold", "wise", "cool", "warm", "bright", "dark", "silent", "loud", "quick", "slow", "happy", "zen", "cosmic", "electric", "quantum", "digital"];
  var nouns = ["fox", "wolf", "eagle", "tiger", "bear", "shark", "hawk", "lion", "dragon", "phoenix", "cobra", "falcon", "raven", "panther", "viper", "lynx", "orca", "jaguar", "puma", "leopard"];

  function generateName() {
    var adj = adjectives[Math.floor(Math.random() * adjectives.length)];
    var noun = nouns[Math.floor(Math.random() * nouns.length)];
    return adj + "-" + noun;
  }

  var nameField = document.getElementById("sandbox_name");
  if (nameField) {
    nameField.value = generateName();
  }

  var mountDataCheckbox = document.getElementById("sandbox_mount_data");
  var dataPathRow = document.getElementById("data_path_row");
  var mountHomeCheckbox = document.getElementById("sandbox_mount_home");
  var homePathRow = document.getElementById("home_path_row");
  var projectSelect = document.getElementById("sandbox_project_id");
  var projectPathInput = document.getElementById("sandbox_project_path");
  var homePathInput = document.getElementById("sandbox_home_path");
  var projectPresetMode = false;
  var toggleDataPath = function() {};
  var toggleHomePath = function() {};
  var syncProjectMode = function() {};
  if (mountDataCheckbox && dataPathRow) {
    toggleDataPath = function() {
      var projectMode = projectPathInput && projectPathInput.value.trim() !== "";
      dataPathRow.style.display = mountDataCheckbox.checked && !projectMode && !projectPresetMode ? "" : "none";
    };
    mountDataCheckbox.addEventListener("change", toggleDataPath);
    toggleDataPath();
  }
  if (mountHomeCheckbox && homePathRow) {
    toggleHomePath = function() {
      var projectMode = projectPathInput && projectPathInput.value.trim() !== "";
      homePathRow.style.display = (!mountHomeCheckbox.checked && !projectMode && !projectPresetMode) ? "" : "none";
    };
    mountHomeCheckbox.addEventListener("change", toggleHomePath);
    toggleHomePath();
  }
  if (projectPathInput) {
    syncProjectMode = function() {
      var projectMode = projectPathInput.value.trim() !== "";
      if (mountHomeCheckbox) {
        mountHomeCheckbox.disabled = projectMode || projectPresetMode;
      }
      if (mountDataCheckbox) {
        mountDataCheckbox.disabled = projectMode || projectPresetMode;
      }
      if (homePathInput) {
        homePathInput.disabled = projectMode || projectPresetMode;
      }
      if (projectMode) {
        if (mountHomeCheckbox) mountHomeCheckbox.checked = false;
        if (mountDataCheckbox) mountDataCheckbox.checked = false;
        if (homePathInput) homePathInput.value = "";
      }
      toggleHomePath();
      toggleDataPath();
    };
    projectPathInput.addEventListener("input", syncProjectMode);
    syncProjectMode();
  }
  if (projectSelect) {
    projectSelect.addEventListener("change", function() {
      projectPresetMode = projectSelect.value !== "";
      syncProjectMode();
      toggleHomePath();
      toggleDataPath();
    });
    projectPresetMode = projectSelect.value !== "";
  }

  var vncCheckbox = document.getElementById("sandbox_vnc_enabled");
  var vncOptionsRow = document.getElementById("vnc_options_row");
  if (vncCheckbox && vncOptionsRow) {
    function toggleVncOptions() {
      vncOptionsRow.style.display = vncCheckbox.checked ? "" : "none";
    }
    vncCheckbox.addEventListener("change", toggleVncOptions);
    toggleVncOptions();
  }
})();
</script>
