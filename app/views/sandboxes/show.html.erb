<% content_for(:title) { "#{@sandbox.name} — Sandcastle" } %>

<div class="max-w-3xl mx-auto px-4 py-6 sm:py-8 space-y-4 sm:space-y-6">
  <%# Header %>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 sm:gap-3 flex-wrap" data-controller="inline-edit">
        <span class="inline-block w-3 h-3 rounded-full shrink-0 <%= @sandbox.status == 'running' ? 'bg-green-500' : @sandbox.status == 'stopped' ? 'bg-yellow-500' : 'bg-gray-400' %>"></span>
        <h1 class="text-xl sm:text-2xl font-bold text-gray-900 font-mono break-all" data-inline-edit-target="display">
          <%= @sandbox.name %>
          <button data-action="click->inline-edit#edit" class="ml-1 text-gray-400 hover:text-gray-600 align-middle" title="Rename">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 inline">
              <path d="M13.488 2.513a1.75 1.75 0 0 0-2.475 0L3.22 10.303a.75.75 0 0 0-.178.311l-.93 3.255a.75.75 0 0 0 .926.926l3.255-.93a.75.75 0 0 0 .311-.178l7.79-7.79a1.75 1.75 0 0 0 0-2.475l-.906-.906ZM11.72 3.22a.25.25 0 0 1 .354 0l.905.906a.25.25 0 0 1 0 .354l-7.79 7.79-1.596.456.455-1.597 7.672-7.91Z" />
            </svg>
          </button>
        </h1>
        <%= form_with model: @sandbox, data: { inline_edit_target: "form" }, class: "hidden items-center gap-2 flex-wrap" do |f| %>
          <%= f.text_field :name, value: @sandbox.name, class: "text-xl sm:text-2xl font-bold font-mono bg-white border border-gray-300 rounded px-2 py-0 w-48 sm:w-64 focus:outline-none focus:ring-2 focus:ring-blue-500", autofocus: true, data: { action: "keydown.escape->inline-edit#cancel" } %>
          <%= f.submit "Save", class: "px-2 py-1 text-sm bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer" %>
          <button type="button" data-action="click->inline-edit#cancel" class="px-2 py-1 text-sm text-gray-600 hover:text-gray-800">Cancel</button>
        <% end %>
        <span class="text-xs font-medium px-2 py-0.5 rounded
          <%= @sandbox.status == 'running' ? 'bg-green-100 text-green-800' :
              @sandbox.status == 'stopped' ? 'bg-yellow-100 text-yellow-800' :
              'bg-gray-100 text-gray-800' %>">
          <%= @sandbox.status %>
        </span>
      </div>
      <p class="text-xs sm:text-sm text-gray-500 mt-1 sm:ml-6 break-all">
        <%= @sandbox.image_version.present? ? @sandbox.image_version : @sandbox.image.sub("ghcr.io/thieso2/", "") %>
        · Created <%= time_ago_in_words(@sandbox.created_at) %> ago
      </p>
    </div>
    <%= link_to root_path, class: "text-sm text-gray-500 hover:text-gray-700 shrink-0 pt-1" do %>
      ← <span class="hidden sm:inline">Dashboard</span>
    <% end %>
  </div>

  <%# Actions %>
  <div class="bg-white rounded-lg border border-gray-200 px-4 sm:px-5 py-3 sm:py-4">
    <div class="flex items-center gap-2 flex-wrap">
      <% if @sandbox.status == "running" %>
        <%= button_to terminal_sandbox_path(@sandbox), method: :post,
              form: { target: "_blank" },
              class: "px-3 py-1.5 bg-gray-700 text-white text-sm rounded hover:bg-gray-800 transition-colors inline-flex items-center gap-1.5" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M3.25 3A2.25 2.25 0 0 0 1 5.25v9.5A2.25 2.25 0 0 0 3.25 17h13.5A2.25 2.25 0 0 0 19 14.75v-9.5A2.25 2.25 0 0 0 16.75 3H3.25Zm.943 8.752a.75.75 0 0 1 .055-1.06L6.128 9l-1.88-1.693a.75.75 0 1 1 1.004-1.114l2.5 2.25a.75.75 0 0 1 0 1.114l-2.5 2.25a.75.75 0 0 1-1.06-.055ZM9.75 10.25a.75.75 0 0 0 0 1.5h2.5a.75.75 0 0 0 0-1.5h-2.5Z" clip-rule="evenodd" />
          </svg>
          Terminal
        <% end %>
        <%= button_to vnc_sandbox_path(@sandbox), method: :post,
              form: { target: "_blank" },
              class: "px-3 py-1.5 bg-blue-600 text-white text-sm rounded hover:bg-blue-700 transition-colors inline-flex items-center gap-1.5" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 0 1.1 1.677A.75.75 0 0 1 13.26 18H6.74a.75.75 0 0 1-.484-1.323A3.501 3.501 0 0 0 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Zm1.5 0a.75.75 0 0 1 .75-.75h11.5a.75.75 0 0 1 .75.75v7.5a.75.75 0 0 1-.75.75H4.25a.75.75 0 0 1-.75-.75v-7.5Z" clip-rule="evenodd" />
          </svg>
          VNC
        <% end %>
        <button type="button"
                onclick="(function(){var d=new Date();var ts='snap-'+d.getFullYear()+(String(d.getMonth()+1).padStart(2,'0'))+(String(d.getDate()).padStart(2,'0'))+'-'+(String(d.getHours()).padStart(2,'0'))+(String(d.getMinutes()).padStart(2,'0'))+(String(d.getSeconds()).padStart(2,'0'));document.getElementById('show-snap-name').value=ts;document.getElementById('create-snapshot-modal').classList.remove('hidden');document.getElementById('show-snap-name').select();})()"
                class="px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded hover:bg-gray-200 transition-colors inline-flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
            <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-6.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
          </svg>
          Snapshot
        </button>
        <%= link_to logs_sandbox_path(@sandbox),
              class: "px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded hover:bg-gray-200 transition-colors inline-flex items-center gap-1.5" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 0 0 3 3.5v13A1.5 1.5 0 0 0 4.5 18h11a1.5 1.5 0 0 0 1.5-1.5V7.621a1.5 1.5 0 0 0-.44-1.06l-4.12-4.122A1.5 1.5 0 0 0 11.378 2H4.5Zm2.25 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Zm0 3a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z" clip-rule="evenodd" />
          </svg>
          Logs
        <% end %>
        <%= link_to "Discover Files", discover_files_sandbox_path(@sandbox),
              class: "px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded hover:bg-gray-200 transition-colors inline-flex items-center gap-1.5" %>
        <%= button_to "Stop", stop_sandbox_path(@sandbox), method: :post,
              class: "px-3 py-1.5 bg-yellow-600 text-white text-sm rounded hover:bg-yellow-700 transition-colors" %>
      <% elsif @sandbox.status == "stopped" %>
        <button type="button"
                onclick="(function(){var d=new Date();var ts='snap-'+d.getFullYear()+(String(d.getMonth()+1).padStart(2,'0'))+(String(d.getDate()).padStart(2,'0'))+'-'+(String(d.getHours()).padStart(2,'0'))+(String(d.getMinutes()).padStart(2,'0'))+(String(d.getSeconds()).padStart(2,'0'));document.getElementById('show-snap-name').value=ts;document.getElementById('create-snapshot-modal').classList.remove('hidden');document.getElementById('show-snap-name').select();})()"
                class="px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded hover:bg-gray-200 transition-colors inline-flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
            <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-6.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
          </svg>
          Snapshot
        </button>
        <%= link_to logs_sandbox_path(@sandbox),
              class: "px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded hover:bg-gray-200 transition-colors inline-flex items-center gap-1.5" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 0 0 3 3.5v13A1.5 1.5 0 0 0 4.5 18h11a1.5 1.5 0 0 0 1.5-1.5V7.621a1.5 1.5 0 0 0-.44-1.06l-4.12-4.122A1.5 1.5 0 0 0 11.378 2H4.5Zm2.25 8.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Zm0 3a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5Z" clip-rule="evenodd" />
          </svg>
          Logs
        <% end %>
        <%= button_to "Start", start_sandbox_path(@sandbox), method: :post,
              class: "px-3 py-1.5 bg-green-600 text-white text-sm rounded hover:bg-green-700 transition-colors" %>
      <% end %>

      <div class="ml-auto">
        <%= button_to "Destroy", sandbox_path(@sandbox), method: :delete,
              data: { confirm: "Destroy #{@sandbox.name}? This cannot be undone." },
              class: "px-3 py-1.5 bg-red-600 text-white text-sm rounded hover:bg-red-700 transition-colors" %>
      </div>
    </div>
  </div>

  <%# Sparklines %>
  <% if @sandbox.status == "running" %>
    <div class="bg-white rounded-lg border border-gray-200 px-5 py-3"
         data-controller="sparkline"
         data-sparkline-metrics-url-value="<%= metrics_sandbox_path(@sandbox, format: :json) %>"
         data-sparkline-stats-url-value="<%= stats_sandbox_path(@sandbox, format: :json) %>">
      <div class="flex items-center gap-6">
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs text-gray-500">CPU</span>
            <span class="text-xs font-mono font-medium" data-sparkline-target="cpuValue">&mdash;</span>
          </div>
          <div data-sparkline-target="cpuChart"></div>
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs text-gray-500">MEM</span>
            <span class="text-xs font-mono font-medium" data-sparkline-target="memValue">&mdash;</span>
          </div>
          <div data-sparkline-target="memChart"></div>
        </div>
      </div>
    </div>
  <% end %>

  <%# SMB Connection Info %>
  <% if @sandbox.smb_enabled? %>
    <div class="bg-white rounded-lg border border-gray-200 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900 mb-3">File Sharing (SMB)</h2>
      <% if @sandbox.tailscale? %>
        <p class="text-sm text-gray-600 mb-3">Connect via SMB3 using your sandbox's Tailscale IP on port 445:</p>
        <div class="space-y-1 text-xs font-mono bg-gray-50 border border-gray-200 rounded p-3">
          <div><span class="text-gray-500">macOS:</span> smb://&lt;tailscale-ip&gt;/home</div>
          <div><span class="text-gray-500">Windows:</span> \\&lt;tailscale-ip&gt;\home</div>
          <% if @sandbox.data_path.present? %>
            <div><span class="text-gray-500">persisted:</span> smb://&lt;tailscale-ip&gt;/persisted</div>
          <% end %>
        </div>
        <p class="text-xs text-gray-500 mt-2">Username: <%= @sandbox.user.name %> · Password: the SMB password set in <%= link_to "Settings", settings_path, class: "text-blue-600 hover:underline" %>.</p>
      <% else %>
        <p class="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded px-3 py-2">
          SMB is enabled but requires Tailscale for access. Enable Tailscale on your account and connect this sandbox.
        </p>
      <% end %>
    </div>
  <% end %>

  <%# Routes %>
  <div class="bg-white rounded-lg border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-base font-semibold text-gray-900">Routes</h2>
    </div>

    <% if @routes.any? %>
      <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Mode</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Domain / Public Port</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Container Port</th>
            <th class="px-4 sm:px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @routes.each do |route| %>
            <tr>
              <td class="px-4 sm:px-6 py-3">
                <% if route.http? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">HTTP</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">TCP</span>
                <% end %>
              </td>
              <td class="px-4 sm:px-6 py-3 font-mono text-gray-900">
                <% if route.http? %>
                  <a href="<%= route.url %>" target="_blank" rel="noopener" class="hover:text-blue-600 break-all"><%= route.domain %></a>
                <% else %>
                  <span class="text-purple-700">:<%= route.public_port %></span>
                <% end %>
              </td>
              <td class="px-4 sm:px-6 py-3 text-gray-600"><%= route.port %></td>
              <td class="px-4 sm:px-6 py-3 text-right">
                <%= button_to "Remove",
                      sandbox_route_path(@sandbox, route),
                      method: :delete,
                      data: { confirm: route.http? ? "Remove route #{route.domain}?" : "Remove TCP route :#{route.public_port}?" },
                      class: "text-red-600 hover:text-red-800 text-xs bg-transparent border-0 cursor-pointer p-0" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <div class="px-6 py-6 text-center text-gray-500 text-sm">
        No routes yet.
      </div>
    <% end %>

    <div class="px-4 sm:px-6 py-4 border-t border-gray-100 bg-gray-50">
      <% if @sandbox.status == "running" %>
        <%= form_with url: sandbox_routes_path(@sandbox), method: :post, class: "space-y-3" do |f| %>
          <div class="flex items-center gap-2">
            <span class="text-xs font-medium text-gray-600">Mode:</span>
            <button type="button" id="route-mode-http"
                    onclick="(function(){document.getElementById('route-mode-input').value='http';document.getElementById('route-domain-field').classList.remove('hidden');document.getElementById('route-tcp-note').classList.add('hidden');document.getElementById('route-mode-http').classList.add('bg-blue-600','text-white');document.getElementById('route-mode-http').classList.remove('bg-gray-100','text-gray-700');document.getElementById('route-mode-tcp').classList.add('bg-gray-100','text-gray-700');document.getElementById('route-mode-tcp').classList.remove('bg-blue-600','text-white');})()"
                    class="px-3 py-1 text-xs font-medium rounded bg-blue-600 text-white transition-colors">HTTP</button>
            <button type="button" id="route-mode-tcp"
                    onclick="(function(){document.getElementById('route-mode-input').value='tcp';document.getElementById('route-domain-field').classList.add('hidden');document.getElementById('route-tcp-note').classList.remove('hidden');document.getElementById('route-mode-tcp').classList.add('bg-blue-600','text-white');document.getElementById('route-mode-tcp').classList.remove('bg-gray-100','text-gray-700');document.getElementById('route-mode-http').classList.add('bg-gray-100','text-gray-700');document.getElementById('route-mode-http').classList.remove('bg-blue-600','text-white');})()"
                    class="px-3 py-1 text-xs font-medium rounded bg-gray-100 text-gray-700 transition-colors">TCP</button>
            <input type="hidden" name="route[mode]" id="route-mode-input" value="http">
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
            <div id="route-domain-field" class="flex-1 min-w-0">
              <%= f.text_field :domain,
                    placeholder: "app.example.com",
                    class: "w-full px-3 py-1.5 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono",
                    name: "route[domain]" %>
            </div>
            <div class="flex items-center gap-2 sm:gap-3">
              <%= f.number_field :port,
                    value: 8080,
                    min: 1,
                    max: 65535,
                    required: true,
                    class: "w-24 px-3 py-1.5 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                    name: "route[port]" %>
              <%= f.submit "Add Route",
                    class: "flex-1 sm:flex-none px-3 py-1.5 bg-blue-600 text-white text-sm font-medium rounded hover:bg-blue-700 cursor-pointer whitespace-nowrap" %>
            </div>
          </div>
          <p id="route-tcp-note" class="hidden text-xs text-gray-500">A public port will be assigned automatically (3000–3099). Enter the container port above.</p>
        <% end %>
      <% else %>
        <p class="text-xs text-gray-400">Start the sandbox to add routes.</p>
      <% end %>
    </div>
  </div>

  <%# Settings %>
  <% smb_ready = @sandbox.user.tailscale_enabled? && @sandbox.user.smb_password.present? %>
  <div class="bg-white rounded-lg border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-900">Settings</h2>
      <% if @sandbox.status == "running" %>
        <span class="text-xs text-gray-500">Stop the sandbox to edit · changes apply on next start</span>
      <% end %>
    </div>
    <div class="px-6 py-4">
      <% editable = @sandbox.status != "running" %>
      <%= form_with model: @sandbox, class: "space-y-4" do |f| %>
        <fieldset <%= 'disabled' if !editable %> class="space-y-4 <%= 'opacity-60' unless editable %>">
          <label class="flex items-start gap-3 <%= 'cursor-pointer' if editable %>">
            <%= f.check_box :ssh_start_tmux,
                  { checked: @sandbox.effective_ssh_start_tmux?,
                    class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" },
                  "1", "0" %>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">Start tmux on SSH login</div>
              <p class="text-xs text-gray-500">Auto-attach to a shared tmux session when you SSH in. Bypass for a single connection with <code class="bg-gray-100 px-1 rounded font-mono">ssh -o SetEnv=NO_TMUX=1 …</code>.</p>
            </div>
          </label>

          <label class="flex items-start gap-3 <%= 'cursor-pointer' if editable %>">
            <%= f.check_box :mount_home,
                  class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">Mount persistent home directory</div>
              <p class="text-xs text-gray-500">Your home directory (~/) will persist across all sandboxes.</p>
            </div>
          </label>

          <label class="flex items-start gap-3 <%= 'cursor-pointer' if editable %>">
            <%= f.check_box :docker_enabled,
                  class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">Start Docker daemon</div>
              <p class="text-xs text-gray-500">Enable Docker-in-Docker support inside the sandbox.</p>
            </div>
          </label>

          <label class="flex items-start gap-3 <%= 'cursor-pointer' if editable %>">
            <%= f.check_box :oidc_enabled,
                  class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">Enable OIDC identity tokens</div>
              <p class="text-xs text-gray-500">Allow this sandbox to mint short-lived tokens for cloud workload federation.</p>
            </div>
          </label>

          <div class="ml-7 space-y-3 border-l border-gray-100 pl-4">
            <label class="flex items-start gap-3 <%= 'cursor-pointer' if editable %>">
              <%= f.check_box :gcp_oidc_enabled,
                    class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
              <div class="flex-1">
                <div class="text-sm font-medium text-gray-900">Configure GCP credentials</div>
                <p class="text-xs text-gray-500">Expose Google external account credentials in this sandbox on next start.</p>
              </div>
            </label>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div class="md:col-span-2">
                <%= f.label :gcp_oidc_config_id, "GCP identity config", class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.select :gcp_oidc_config_id,
                      options_for_select([["None", ""]] + @gcp_oidc_configs.map { |config| [config.name, config.id] }, @sandbox.gcp_oidc_config_id),
                      {},
                      class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
              </div>
              <div class="md:col-span-2">
                <%= f.label :gcp_service_account_email, "Custom service account override", class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.email_field :gcp_service_account_email,
                      placeholder: @sandbox.gcp_oidc_config&.default_service_account_email || "sandcastle-reader@project.iam.gserviceaccount.com",
                      class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" %>
                <p class="mt-1 text-xs text-gray-500">Leave blank to use the config's default read-only Sandcastle service account.</p>
              </div>
              <div>
                <%= f.label :gcp_principal_scope, "Principal scope", class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= f.select :gcp_principal_scope,
                      options_for_select([["All my sandboxes", "user"], ["This sandbox", "sandbox"]], @sandbox.gcp_principal_scope),
                      {},
                      class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
              </div>
              <div>
                <%= label_tag "sandbox_gcp_roles_text", "Project roles", class: "block text-xs font-medium text-gray-600 mb-1" %>
                <%= text_field_tag "sandbox[gcp_roles_text]", @sandbox.gcp_roles_list.join(", "),
                      id: "sandbox_gcp_roles_text",
                      placeholder: "roles/viewer, roles/storage.objectViewer",
                      class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" %>
              </div>
            </div>
          </div>

          <label class="flex items-start gap-3 <%= 'cursor-pointer' if editable %>">
            <%= f.check_box :vnc_enabled,
                  class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">Enable VNC display</div>
              <p class="text-xs text-gray-500">Start a virtual display (Xvnc) for GUI apps and browser access.</p>
            </div>
          </label>

          <div class="grid grid-cols-2 gap-3 ml-7 max-w-md">
            <div>
              <%= f.label :vnc_geometry, "Resolution", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.select :vnc_geometry,
                    options_for_select(Sandbox::VNC_GEOMETRIES.map { |g| [g.sub("x", "×"), g] }, @sandbox.vnc_geometry),
                    {},
                    class: "block w-full text-sm border border-gray-300 rounded px-2 py-1" %>
            </div>
            <div>
              <%= f.label :vnc_depth, "Color depth", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.select :vnc_depth,
                    options_for_select(Sandbox::VNC_DEPTHS.map { |d| ["#{d}-bit", d] }, @sandbox.vnc_depth),
                    {},
                    class: "block w-full text-sm border border-gray-300 rounded px-2 py-1" %>
            </div>
          </div>

          <label class="flex items-start gap-3 <%= smb_ready && editable ? 'cursor-pointer' : 'opacity-70' %>">
            <%= f.check_box :smb_enabled,
                  disabled: !smb_ready,
                  title: smb_ready ? nil : "Requires Tailscale enabled and an SMB password set in Settings",
                  class: "mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">Enable SMB file sharing</div>
              <% if smb_ready %>
                <p class="text-xs text-gray-500">Mount home/persisted as a network drive via SMB3 over Tailscale.</p>
              <% else %>
                <p class="text-xs text-gray-500">
                  Requires Tailscale enabled and an SMB password —
                  <%= link_to "configure in Settings", settings_path, class: "text-blue-600 hover:underline" %>.
                </p>
              <% end %>
            </div>
          </label>

          <% if editable %>
            <div class="pt-2">
              <%= f.submit "Save Settings", class: "px-4 py-2 bg-blue-600 text-white text-sm rounded hover:bg-blue-700 cursor-pointer" %>
              <span class="ml-2 text-xs text-gray-500">Changes apply on next sandbox rebuild/start.</span>
            </div>
          <% end %>
        </fieldset>
      <% end %>
    </div>
  </div>

  <%# GCP Identity %>
  <div class="bg-white rounded-lg border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-900">GCP Identity</h2>
      <% if @sandbox.gcp_oidc_configured? %>
        <span class="text-xs font-medium text-green-700 bg-green-50 border border-green-200 rounded px-2 py-1">Configured</span>
      <% else %>
        <span class="text-xs font-medium text-gray-600 bg-gray-50 border border-gray-200 rounded px-2 py-1">Not active</span>
      <% end %>
    </div>
    <div class="px-6 py-4 space-y-4">
      <% if @gcp_oidc_setup[:missing].present? %>
        <div class="rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">
          Missing: <code class="font-mono"><%= @gcp_oidc_setup[:missing].join(", ") %></code>
        </div>
      <% end %>

      <% if @gcp_oidc_setup[:audience].present? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
          <div>
            <div class="text-xs font-medium text-gray-500 mb-1">Config</div>
            <code class="block bg-gray-50 border border-gray-200 rounded px-2 py-1 font-mono text-xs break-all"><%= @gcp_oidc_setup[:config_name].presence || "None" %></code>
          </div>
          <div>
            <div class="text-xs font-medium text-gray-500 mb-1">Service account</div>
            <code class="block bg-gray-50 border border-gray-200 rounded px-2 py-1 font-mono text-xs break-all"><%= @gcp_oidc_setup[:service_account_email] %></code>
          </div>
          <div>
            <div class="text-xs font-medium text-gray-500 mb-1">Issuer</div>
            <code class="block bg-gray-50 border border-gray-200 rounded px-2 py-1 font-mono text-xs break-all"><%= @gcp_oidc_setup[:issuer] %></code>
          </div>
          <div>
            <div class="text-xs font-medium text-gray-500 mb-1">Audience</div>
            <code class="block bg-gray-50 border border-gray-200 rounded px-2 py-1 font-mono text-xs break-all"><%= @gcp_oidc_setup[:audience] %></code>
          </div>
          <div class="md:col-span-2">
            <div class="text-xs font-medium text-gray-500 mb-1">Principal</div>
            <code class="block bg-gray-50 border border-gray-200 rounded px-2 py-1 font-mono text-xs break-all"><%= @gcp_oidc_setup[:principal].presence || "Configure a service account and scope to generate the IAM principal." %></code>
          </div>
        </div>
      <% end %>

      <% if @gcp_oidc_setup[:shell].present? %>
        <div>
          <div class="text-xs font-medium text-gray-500 mb-1">GCP setup commands</div>
          <pre class="overflow-x-auto rounded border border-gray-200 bg-gray-950 text-gray-100 p-3 text-xs leading-relaxed"><code><%= @gcp_oidc_setup[:shell] %></code></pre>
        </div>
      <% end %>

      <% if @gcp_oidc_setup[:environment].present? %>
        <div>
          <div class="text-xs font-medium text-gray-500 mb-1">Sandbox environment</div>
          <pre class="overflow-x-auto rounded border border-gray-200 bg-gray-50 p-3 text-xs leading-relaxed"><code><%= @gcp_oidc_setup[:environment].map { |key, value| "#{key}=#{value}" }.join("\n") %></code></pre>
        </div>
      <% end %>
    </div>
  </div>

  <%# Snapshots %>
  <div class="bg-white rounded-lg border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-900">Snapshots</h2>
      <button
        onclick="(function(){var d=new Date();var ts='snap-'+d.getFullYear()+(String(d.getMonth()+1).padStart(2,'0'))+(String(d.getDate()).padStart(2,'0'))+'-'+(String(d.getHours()).padStart(2,'0'))+(String(d.getMinutes()).padStart(2,'0'))+(String(d.getSeconds()).padStart(2,'0'));document.getElementById('show-snap-name').value=ts;document.getElementById('create-snapshot-modal').classList.remove('hidden');document.getElementById('show-snap-name').select();})()"
        class="px-3 py-1.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
        + Create Snapshot
      </button>
    </div>

    <% if @sandbox_snapshots.empty? %>
      <div class="px-4 sm:px-6 py-8 text-center text-gray-500 text-sm">
        No snapshots yet. Create one to save the current state of this sandbox.
      </div>
    <% else %>
      <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Layers</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-4 sm:px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @sandbox_snapshots.each do |snap| %>
            <tr>
              <td class="px-4 sm:px-6 py-3 font-medium text-gray-900 font-mono">
                <%= snap[:name] %>
                <% if snap[:label].present? %>
                  <span class="block text-xs text-gray-500 font-sans font-normal"><%= snap[:label] %></span>
                <% end %>
              </td>
              <td class="px-4 sm:px-6 py-3 text-gray-600">
                <% (snap[:layers] || []).each do |layer| %>
                  <span class="inline-block px-1.5 py-0.5 bg-blue-100 text-blue-700 text-xs rounded mr-1"><%= layer[0].upcase %></span>
                <% end %>
              </td>
              <td class="px-4 sm:px-6 py-3 text-gray-600 whitespace-nowrap">
                <%= number_to_human_size(snap[:total_size] || 0) %>
              </td>
              <td class="px-4 sm:px-6 py-3 text-gray-500 text-xs whitespace-nowrap">
                <%= snap[:created_at]&.strftime("%Y-%m-%d %H:%M") %>
              </td>
              <td class="px-4 sm:px-6 py-3 text-right">
                <div class="flex items-center gap-3 justify-end">
                  <%= link_to "New sandbox", new_sandbox_path(snapshot: snap[:name]),
                        class: "text-blue-600 hover:text-blue-800 text-xs whitespace-nowrap" %>
                  <%= button_to "Delete",
                        snapshot_path(snap[:name]),
                        method: :delete,
                        data: { confirm: "Delete snapshot \"#{snap[:name]}\"?" },
                        class: "text-red-600 hover:text-red-800 text-xs bg-transparent border-0 cursor-pointer p-0" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% end %>
  </div>
</div>

<%# Create Snapshot Modal %>
<div id="create-snapshot-modal" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50" onclick="if(event.target===this)this.classList.add('hidden')">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-gray-900">Create Snapshot</h3>
      <button onclick="document.getElementById('create-snapshot-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-lg leading-none">✕</button>
    </div>

    <%= form_with url: snapshot_sandbox_path(@sandbox), method: :post, class: "px-6 py-4 space-y-4" do |f| %>
      <div>
        <%= f.text_field :name,
              required: true,
              id: "show-snap-name",
              pattern: "[a-z][a-z0-9_\\-]*",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm font-mono" %>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-700 mb-2">Layers to include</p>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-sm">
            <input type="checkbox" name="layers[]" value="container" checked class="h-4 w-4 text-blue-600 border-gray-300 rounded">
            Container filesystem (docker commit)
          </label>
          <% if @sandbox.mount_home && @btrfs %>
            <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" name="layers[]" value="home" checked class="h-4 w-4 text-blue-600 border-gray-300 rounded">
              Home directory
            </label>
          <% end %>
          <% if @sandbox.data_path.present? && @btrfs %>
            <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" name="layers[]" value="data" checked class="h-4 w-4 text-blue-600 border-gray-300 rounded">
              Data directory (<%= @sandbox.data_path %>)
            </label>
          <% end %>
          <% unless @btrfs %>
            <p class="text-xs text-gray-500 bg-yellow-50 border border-yellow-200 rounded p-2">
              BTRFS not detected — only the container layer is available.
            </p>
          <% end %>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('create-snapshot-modal').classList.add('hidden')"
                class="px-4 py-2 text-sm text-gray-700 hover:text-gray-900">Cancel</button>
        <%= f.submit "Create Snapshot",
              class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
