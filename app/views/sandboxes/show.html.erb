<% content_for(:title) { "#{@sandbox.name} — Sandcastle" } %>

<div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
  <%# Header %>
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-3">
        <span class="inline-block w-3 h-3 rounded-full <%= @sandbox.status == 'running' ? 'bg-green-500' : @sandbox.status == 'stopped' ? 'bg-yellow-500' : 'bg-gray-400' %>"></span>
        <h1 class="text-2xl font-bold text-gray-900 font-mono"><%= @sandbox.name %></h1>
        <span class="text-xs font-medium px-2 py-0.5 rounded
          <%= @sandbox.status == 'running' ? 'bg-green-100 text-green-800' :
              @sandbox.status == 'stopped' ? 'bg-yellow-100 text-yellow-800' :
              'bg-gray-100 text-gray-800' %>">
          <%= @sandbox.status %>
        </span>
      </div>
      <p class="text-sm text-gray-500 mt-1 ml-6">
        <%= @sandbox.image.sub("ghcr.io/thieso2/", "") %>
        · SSH port <%= @sandbox.ssh_port %>
        · Created <%= time_ago_in_words(@sandbox.created_at) %> ago
      </p>
    </div>
    <%= link_to root_path, class: "text-sm text-gray-500 hover:text-gray-700 shrink-0" do %>
      ← Dashboard
    <% end %>
  </div>

  <%# Actions %>
  <div class="bg-white rounded-lg border border-gray-200 px-5 py-4">
    <div class="flex items-center gap-2 flex-wrap">
      <% if @sandbox.status == "running" %>
        <%= button_to terminal_sandbox_path(@sandbox), method: :post,
              form: { target: "_blank" },
              class: "px-3 py-1.5 bg-gray-700 text-white text-sm rounded hover:bg-gray-800 transition-colors inline-flex items-center gap-1.5" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M3.25 3A2.25 2.25 0 0 0 1 5.25v9.5A2.25 2.25 0 0 0 3.25 17h13.5A2.25 2.25 0 0 0 19 14.75v-9.5A2.25 2.25 0 0 0 16.75 3H3.25Zm.943 8.752a.75.75 0 0 1 .055-1.06L6.128 9l-1.88-1.693a.75.75 0 1 1 1.004-1.114l2.5 2.25a.75.75 0 0 1 0 1.114l-2.5 2.25a.75.75 0 0 1-1.06-.055ZM9.75 10.25a.75.75 0 0 0 0 1.5h2.5a.75.75 0 0 0 0-1.5h-2.5Z" clip-rule="evenodd" />
          </svg>
          Terminal
        <% end %>
        <%= button_to vnc_sandbox_path(@sandbox), method: :post,
              form: { target: "_blank" },
              class: "px-3 py-1.5 bg-blue-600 text-white text-sm rounded hover:bg-blue-700 transition-colors inline-flex items-center gap-1.5" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M2 4.25A2.25 2.25 0 0 1 4.25 2h11.5A2.25 2.25 0 0 1 18 4.25v8.5A2.25 2.25 0 0 1 15.75 15h-3.105a3.501 3.501 0 0 0 1.1 1.677A.75.75 0 0 1 13.26 18H6.74a.75.75 0 0 1-.484-1.323A3.501 3.501 0 0 0 7.355 15H4.25A2.25 2.25 0 0 1 2 12.75v-8.5Zm1.5 0a.75.75 0 0 1 .75-.75h11.5a.75.75 0 0 1 .75.75v7.5a.75.75 0 0 1-.75.75H4.25a.75.75 0 0 1-.75-.75v-7.5Z" clip-rule="evenodd" />
          </svg>
          Browser
        <% end %>
        <button type="button"
                onclick="document.getElementById('create-snapshot-modal').classList.remove('hidden')"
                class="px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded hover:bg-gray-200 transition-colors inline-flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
            <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-6.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
          </svg>
          Snapshot
        </button>
        <%= button_to "Stop", stop_sandbox_path(@sandbox), method: :post,
              class: "px-3 py-1.5 bg-yellow-600 text-white text-sm rounded hover:bg-yellow-700 transition-colors" %>
      <% elsif @sandbox.status == "stopped" %>
        <button type="button"
                onclick="document.getElementById('create-snapshot-modal').classList.remove('hidden')"
                class="px-3 py-1.5 bg-gray-100 text-gray-700 text-sm rounded hover:bg-gray-200 transition-colors inline-flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
            <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-6.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
          </svg>
          Snapshot
        </button>
        <%= button_to "Start", start_sandbox_path(@sandbox), method: :post,
              class: "px-3 py-1.5 bg-green-600 text-white text-sm rounded hover:bg-green-700 transition-colors" %>
      <% end %>

      <div class="ml-auto">
        <%= button_to "Destroy", sandbox_path(@sandbox), method: :delete,
              data: { confirm: "Destroy #{@sandbox.name}? This cannot be undone." },
              class: "px-3 py-1.5 bg-red-600 text-white text-sm rounded hover:bg-red-700 transition-colors" %>
      </div>
    </div>
  </div>

  <%# Snapshots %>
  <div class="bg-white rounded-lg border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-900">Snapshots</h2>
      <button
        onclick="document.getElementById('create-snapshot-modal').classList.remove('hidden')"
        class="px-3 py-1.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
        + Create Snapshot
      </button>
    </div>

    <% if @sandbox_snapshots.empty? %>
      <div class="px-6 py-8 text-center text-gray-500 text-sm">
        No snapshots yet. Create one to save the current state of this sandbox.
      </div>
    <% else %>
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Layers</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @sandbox_snapshots.each do |snap| %>
            <tr>
              <td class="px-6 py-3 font-medium text-gray-900 font-mono">
                <%= snap[:name] %>
                <% if snap[:label].present? %>
                  <span class="block text-xs text-gray-500 font-sans font-normal"><%= snap[:label] %></span>
                <% end %>
              </td>
              <td class="px-6 py-3 text-gray-600">
                <% (snap[:layers] || []).each do |layer| %>
                  <span class="inline-block px-1.5 py-0.5 bg-blue-100 text-blue-700 text-xs rounded mr-1"><%= layer[0].upcase %></span>
                <% end %>
              </td>
              <td class="px-6 py-3 text-gray-600">
                <%= number_to_human_size(snap[:total_size] || 0) %>
              </td>
              <td class="px-6 py-3 text-gray-500 text-xs">
                <%= snap[:created_at]&.strftime("%Y-%m-%d %H:%M") %>
              </td>
              <td class="px-6 py-3 text-right">
                <div class="flex items-center gap-3 justify-end">
                  <%= link_to "New sandbox", new_sandbox_path(snapshot: snap[:name]),
                        class: "text-blue-600 hover:text-blue-800 text-xs" %>
                  <%= button_to "Delete",
                        snapshot_path(snap[:name]),
                        method: :delete,
                        data: { confirm: "Delete snapshot \"#{snap[:name]}\"?" },
                        class: "text-red-600 hover:text-red-800 text-xs bg-transparent border-0 cursor-pointer p-0" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>

<%# Create Snapshot Modal %>
<div id="create-snapshot-modal" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50" onclick="if(event.target===this)this.classList.add('hidden')">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-gray-900">Create Snapshot</h3>
      <button onclick="document.getElementById('create-snapshot-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-lg leading-none">✕</button>
    </div>

    <%= form_with url: sandbox_snapshot_path(@sandbox), method: :post, class: "px-6 py-4 space-y-4" do |f| %>
      <div>
        <%= f.label :name, "Snapshot Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name,
              required: true,
              placeholder: Date.today.iso8601,
              pattern: "[a-z][a-z0-9_\\-]*",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" %>
      </div>

      <div>
        <%= f.label :label, "Description (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :label,
              placeholder: "e.g. before migration",
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" %>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-700 mb-2">Layers to include</p>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-sm">
            <input type="checkbox" name="layers[]" value="container" checked class="h-4 w-4 text-blue-600 border-gray-300 rounded">
            Container filesystem (docker commit)
          </label>
          <% if @sandbox.mount_home && @btrfs %>
            <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" name="layers[]" value="home" checked class="h-4 w-4 text-blue-600 border-gray-300 rounded">
              Home directory
            </label>
          <% end %>
          <% if @sandbox.data_path.present? && @btrfs %>
            <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" name="layers[]" value="data" checked class="h-4 w-4 text-blue-600 border-gray-300 rounded">
              Data directory (<%= @sandbox.data_path %>)
            </label>
          <% end %>
          <% if @sandbox.persistent_volume && @btrfs %>
            <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" name="layers[]" value="workspace" checked class="h-4 w-4 text-blue-600 border-gray-300 rounded">
              Workspace volume
            </label>
          <% end %>
          <% unless @btrfs %>
            <p class="text-xs text-gray-500 bg-yellow-50 border border-yellow-200 rounded p-2">
              BTRFS not detected — only the container layer is available.
            </p>
          <% end %>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('create-snapshot-modal').classList.add('hidden')"
                class="px-4 py-2 text-sm text-gray-700 hover:text-gray-900">Cancel</button>
        <%= f.submit "Create Snapshot",
              class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
